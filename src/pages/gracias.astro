---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gracias" description="Mensaje enviado correctamente.">
  <section class="section">
    <div class="container-site max-w-2xl text-center">
      <p class="eyebrow">Mensaje enviado</p>
      <h1 class="mt-2 font-serif text-3xl md:text-4xl text-ink">¡Gracias!</h1>
      <div class="divider"></div>
      <p class="text-ink/75">
        Hemos recibido su mensaje. Un miembro de nuestro equipo se pondrá en
        contacto con usted a la brevedad.
      </p>
      <div class="mt-8">
        <a href="/" class="btn-outline">Volver al inicio</a>
      </div>
    </div>
  </section>
</Layout>
