---
import Layout from "../layouts/Layout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ContactForm from "../components/ContactForm.astro";
import { getSiteSettings } from "../lib/settings";

const { contact } = await getSiteSettings();
const phoneClean = (p?: string) => (p ? p.replace(/[^+\d]/g, "") : "");
---

<Layout
  title="Contacto"
  description="Contáctenos. Ortega & Ortega Abogados — Firma de abogados penalistas y constitucionalistas en Ecuador."
>
  <section class="section bg-bone-200">
    <div class="container-site">
      <SectionTitle eyebrow="Hablemos" title="Contacto" gold={true} />

      <div class="grid gap-12 lg:grid-cols-2 items-start">
        <div>
          <p class="text-base text-ink-800/85 leading-relaxed mb-8">
            Estamos a su disposición para brindarle una asesoría eficaz,
            integral y oportuna. Complete el formulario y nos pondremos en
            contacto con usted a la brevedad.
          </p>

          <ul class="space-y-5 text-sm">
            {contact?.address && (
              <li class="flex gap-4">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold/10 text-gold-dark">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </span>
                <div>
                  <p class="text-xs uppercase tracking-widest text-ink-600">Dirección</p>
                  <p class="mt-1 leading-relaxed">{contact.address}</p>
                </div>
              </li>
            )}

            {contact?.phone && (
              <li class="flex gap-4">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold/10 text-gold-dark">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"></path>
                  </svg>
                </span>
                <div>
                  <p class="text-xs uppercase tracking-widest text-ink-600">Teléfono fijo</p>
                  <a href={`tel:${phoneClean(contact.phone)}`} class="mt-1 inline-block hover:text-gold-dark">
                    {contact.phone}
                  </a>
                </div>
              </li>
            )}

            {(contact?.mobile || contact?.mobile2) && (
              <li class="flex gap-4">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold/10 text-gold-dark">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
                    <line x1="12" y1="18" x2="12.01" y2="18"></line>
                  </svg>
                </span>
                <div>
                  <p class="text-xs uppercase tracking-widest text-ink-600">Móvil</p>
                  {contact.mobile && (
                    <a href={`tel:${phoneClean(contact.mobile)}`} class="block mt-1 hover:text-gold-dark">
                      {contact.mobile}
                    </a>
                  )}
                  {contact.mobile2 && (
                    <a href={`tel:${phoneClean(contact.mobile2)}`} class="block hover:text-gold-dark">
                      {contact.mobile2}
                    </a>
                  )}
                </div>
              </li>
            )}

            {contact?.email && (
              <li class="flex gap-4">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold/10 text-gold-dark">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                </span>
                <div>
                  <p class="text-xs uppercase tracking-widest text-ink-600">Email</p>
                  <a href={`mailto:${contact.email}`} class="mt-1 inline-block hover:text-gold-dark break-all">
                    {contact.email}
                  </a>
                </div>
              </li>
            )}

            {contact?.whatsapp && (
              <li class="flex gap-4">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#25D366]/10 text-[#25D366]">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-xs uppercase tracking-widest text-ink-600">WhatsApp</p>
                  <a href={contact.whatsapp} target="_blank" rel="noopener" class="mt-1 inline-block hover:text-gold-dark">
                    Escríbanos por WhatsApp
                  </a>
                </div>
              </li>
            )}
          </ul>
        </div>

        <div>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  {contact?.mapsEmbed && (
    <section class="pb-16 md:pb-24 bg-bone-200">
      <div class="container-site">
        <div class="aspect-[16/9] w-full overflow-hidden border border-ink/10 rounded-sm">
          <iframe
            src={contact.mapsEmbed}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación"
          />
        </div>
      </div>
    </section>
  )}
</Layout>
