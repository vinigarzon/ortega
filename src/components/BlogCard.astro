---
import BrandedPlaceholder from "./BrandedPlaceholder.astro";

interface Props {
  href: string;
  title: string;
  date: Date;
  excerpt?: string;
  category?: string;
  featuredImage?: string;
  ctaLabel?: string;
}

const {
  href,
  title,
  date,
  excerpt,
  category,
  featuredImage,
  ctaLabel = "Leer más →",
} = Astro.props;

const dateFmt = new Intl.DateTimeFormat("es-EC", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(date);

const hasImage = featuredImage && featuredImage.trim() !== "";
---

<article
  class="group flex h-full flex-col overflow-hidden bg-white border border-ink/10 shadow-sm transition-all hover:shadow-lg hover:-translate-y-0.5"
>
  <a href={href} class="block aspect-[16/10] overflow-hidden bg-ink/5">
    {hasImage ? (
      <img
        src={featuredImage}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="h-full w-full transition-transform duration-500 group-hover:scale-105">
        <BrandedPlaceholder title={title} eyebrow={category ?? "Artículo"} />
      </div>
    )}
  </a>
  <div class="flex flex-1 flex-col p-5 md:p-6">
    {category && <p class="eyebrow">{category}</p>}
    <h3 class="mt-2 font-serif text-xl leading-snug text-ink">
      <a href={href} class="hover:text-gold-dark">{title}</a>
    </h3>
    {excerpt && (
      <p class="mt-3 text-sm leading-relaxed text-ink/70 line-clamp-3">
        {excerpt}
      </p>
    )}
    <div class="mt-5 flex items-center justify-between border-t border-ink/10 pt-4">
      <time datetime={date.toISOString()} class="text-xs uppercase tracking-widest text-ink/50">
        {dateFmt}
      </time>
      <a
        href={href}
        class="text-xs font-semibold uppercase tracking-widest text-gold hover:text-gold-dark"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</article>
