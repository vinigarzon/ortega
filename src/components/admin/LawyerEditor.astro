---
/**
 * Editor de miembro del equipo — 2 columnas con FormSections,
 * sticky save bar, toast feedback, confirm dialog para delete.
 */
import type { Lawyer } from "@/lib/queries";

interface Props {
  lawyer?: Lawyer;
  mode: "create" | "edit";
}
const { lawyer, mode } = Astro.props;

const initial = {
  name: lawyer?.name ?? "",
  slug: lawyer?.slug ?? "",
  position: lawyer?.position ?? "",
  photo: lawyer?.photo ?? "",
  photoZoom: lawyer?.photoZoom ?? 1,
  photoFocusY: lawyer?.photoFocusY ?? 18,
  specialty: lawyer?.specialty ?? "",
  phone: lawyer?.phone ?? "",
  email: lawyer?.email ?? "",
  bio: lawyer?.bio ?? "",
  order: lawyer?.order ?? 99,
  active: lawyer?.active ?? true,
};
---

<form id="lawyerForm" class="editor-form" data-mode={mode} data-original-slug={lawyer?.slug ?? ""}>
  <div class="editor-grid">

    {/* ============ MAIN COLUMN ============ */}
    <div class="editor-main card card-pad-0">

      <div class="form-section">
        <div class="form-section__head">
          <h3>Datos básicos</h3>
          <p>Información que aparece en las cards de la sección "Nuestro Equipo".</p>
        </div>
        <div class="form-grid">
          <div class="field">
            <label class="field-label" for="name">Nombre completo</label>
            <input id="name" name="name" type="text" class="input input-display" required value={initial.name} placeholder="Ej. Jorge Luis Ortega" />
          </div>
          <div class="form-grid form-grid-2">
            <div class="field">
              <label class="field-label" for="position">Cargo</label>
              <input id="position" name="position" type="text" class="input" required value={initial.position} placeholder="Socio Gerente / Asociada Senior…" />
            </div>
            <div class="field">
              <label class="field-label" for="specialty">Especialidad</label>
              <input id="specialty" name="specialty" type="text" class="input" value={initial.specialty} placeholder="Derecho Penal y Constitucional" />
            </div>
          </div>
          <div class="field">
            <label class="field-label" for="slug">Slug (URL interna)</label>
            <input id="slug" name="slug" type="text" class="input" value={initial.slug} placeholder="se-genera-del-nombre" />
            <small class="field-help">Identificador único interno. Si lo dejas vacío, se genera del nombre.</small>
          </div>
        </div>
      </div>

      <div class="form-section">
        <div class="form-section__head">
          <h3>Contacto</h3>
          <p>Aparece en la card al hacer hover sobre la foto.</p>
        </div>
        <div class="form-grid form-grid-2">
          <div class="field">
            <label class="field-label" for="phone">Teléfono</label>
            <input id="phone" name="phone" type="text" class="input" value={initial.phone} placeholder="099 980 8183" />
          </div>
          <div class="field">
            <label class="field-label" for="email">Email</label>
            <input id="email" name="email" type="email" class="input" value={initial.email} placeholder="nombre@ortegaabogados.com" />
          </div>
        </div>
      </div>

      <div class="form-section">
        <div class="form-section__head">
          <h3>Biografía</h3>
          <p>Texto corto opcional que describe la trayectoria de la persona.</p>
        </div>
        <div class="field">
          <textarea id="bio" name="bio" class="textarea" rows="8" placeholder="Master en Derecho Penal. Ex-Fiscal. Profesor de Sistema Penal Juvenil…">{initial.bio}</textarea>
        </div>
      </div>
    </div>

    {/* ============ SIDE COLUMN ============ */}
    <aside class="editor-side">
      <div class="card">
        <h4 class="side-head">Foto</h4>
        <div class="field">
          <input id="photo" name="photo" type="text" data-upload="1" value={initial.photo} placeholder="Subir o pegar URL…" />
        </div>
        <div class="form-grid form-grid-2" style="margin-top: 14px;">
          <div class="field">
            <label class="field-label" for="photoZoom">Zoom</label>
            <input id="photoZoom" name="photoZoom" type="number" min="0.6" max="2" step="0.05" class="input" value={initial.photoZoom} />
            <small class="field-help">1 = sin zoom</small>
          </div>
          <div class="field">
            <label class="field-label" for="photoFocusY">Foco Y (%)</label>
            <input id="photoFocusY" name="photoFocusY" type="number" min="0" max="100" step="1" class="input" value={initial.photoFocusY} />
            <small class="field-help">0 arriba · 50 centro · 100 abajo</small>
          </div>
        </div>
      </div>

      <div class="card">
        <h4 class="side-head">Estado y orden</h4>
        <div class="field">
          <label class="field-label" for="order">Orden de aparición</label>
          <input id="order" name="order" type="number" min="1" class="input" value={initial.order} />
          <small class="field-help">Menor número = aparece primero</small>
        </div>
        <div class="field" style="margin-top: 14px;">
          <label class="checkbox-row">
            <input type="checkbox" name="active" id="active" checked={initial.active} />
            <span>Visible en el sitio público</span>
          </label>
        </div>
      </div>

      {lawyer && (
        <div class="card danger-zone">
          <h4 class="side-head">Zona destructiva</h4>
          <p class="danger-help">Eliminar este miembro lo quita inmediatamente del sitio.</p>
          <button type="button" class="btn btn-danger-ghost" id="deleteBtn">
            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            Eliminar miembro
          </button>
        </div>
      )}
    </aside>
  </div>

  <div class="save-bar">
    <div class="save-bar__status" id="saveStatus">{mode === "edit" ? "Sin cambios pendientes" : "Aún sin guardar"}</div>
    <a class="btn btn-ghost" href="/admin/lawyers">Cancelar</a>
    <button type="submit" class="btn btn-primary" id="saveBtn">
      <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      {mode === "create" ? "Crear miembro" : "Guardar cambios"}
    </button>
  </div>

  <style>
    .editor-grid {
      display: grid; grid-template-columns: 1fr 320px; gap: 24px;
      align-items: flex-start;
    }
    .editor-main { padding: 0; overflow: hidden; }
    .editor-side { display: flex; flex-direction: column; gap: 16px; }
    .editor-side .card { padding: 18px 20px; }
    .side-head {
      font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
      color: var(--c-text-soft); font-weight: 600; margin: 0 0 14px;
    }
    .danger-zone { border-color: var(--c-danger-bg) !important; background: linear-gradient(180deg, #fef7f7 0%, var(--c-surface) 100%); }
    .danger-help { font-size: 12.5px; color: var(--c-text-dim); margin-bottom: 12px; }

    @media (max-width: 1100px) {
      .editor-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
  (function () {
    const form = document.getElementById("lawyerForm");
    const saveBtn = document.getElementById("saveBtn");
    const saveStatus = document.getElementById("saveStatus");
    const deleteBtn = document.getElementById("deleteBtn");
    const mode = form.dataset.mode;
    const originalSlug = form.dataset.originalSlug;
    let dirty = false;

    function markDirty() {
      if (!dirty) { dirty = true; saveStatus.innerHTML = `<span class="err">●</span> Hay cambios sin guardar`; }
    }
    form.querySelectorAll("input, textarea, select").forEach((el) => {
      el.addEventListener("input", markDirty);
      el.addEventListener("change", markDirty);
    });

    window.addEventListener("beforeunload", (e) => { if (dirty) { e.preventDefault(); e.returnValue = ""; } });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      saveBtn.disabled = true;
      const origText = saveBtn.innerHTML;
      saveBtn.innerHTML = "Guardando…";

      const fd = new FormData(form);
      const payload = {
        name: fd.get("name"),
        position: fd.get("position"),
        specialty: fd.get("specialty"),
        phone: fd.get("phone"),
        email: fd.get("email"),
        bio: fd.get("bio"),
        photo: fd.get("photo"),
        photoZoom: parseFloat(fd.get("photoZoom") || "1") || 1,
        photoFocusY: parseInt(fd.get("photoFocusY") || "18", 10) || 18,
        order: parseInt(fd.get("order") || "99", 10) || 99,
        active: !!fd.get("active"),
      };

      try {
        let res;
        if (mode === "create") {
          payload.slug = fd.get("slug");
          res = await fetch("/api/admin/lawyers", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        } else {
          payload.newSlug = fd.get("slug");
          res = await fetch(`/api/admin/lawyers/${encodeURIComponent(originalSlug)}`, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        }
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          saveBtn.disabled = false; saveBtn.innerHTML = origText;
          saveStatus.innerHTML = `<span class="err">●</span> ${data.error || "Error al guardar"}`;
          window.toast && toast("error", "No se pudo guardar", data.error || "Inténtalo de nuevo");
          return;
        }
        dirty = false;
        saveStatus.innerHTML = `<span class="ok">✓</span> Guardado`;
        window.toast && toast("success", "Cambios guardados", "El equipo se actualizó en el sitio.");
        if (mode === "create" || (data.slug && data.slug !== originalSlug)) {
          setTimeout(() => { window.location.href = `/admin/lawyers/${encodeURIComponent(data.slug)}`; }, 600);
          return;
        }
        saveBtn.disabled = false; saveBtn.innerHTML = origText;
      } catch {
        saveBtn.disabled = false; saveBtn.innerHTML = origText;
        saveStatus.innerHTML = `<span class="err">●</span> Error de red`;
        window.toast && toast("error", "Error de red", "Verifica tu conexión.");
      }
    });

    if (deleteBtn) {
      deleteBtn.addEventListener("click", async () => {
        const ok = await window.confirmDialog({
          title: "¿Eliminar miembro del equipo?",
          message: "Esta acción no se puede deshacer. La persona dejará de aparecer en el sitio.",
          confirmLabel: "Sí, eliminar",
        });
        if (!ok) return;
        deleteBtn.disabled = true;
        try {
          const res = await fetch(`/api/admin/lawyers/${encodeURIComponent(originalSlug)}`, { method: "DELETE" });
          if (!res.ok) { deleteBtn.disabled = false; window.toast && toast("error", "No se pudo eliminar"); return; }
          dirty = false;
          window.toast && toast("success", "Miembro eliminado");
          setTimeout(() => { window.location.href = "/admin/lawyers"; }, 500);
        } catch {
          deleteBtn.disabled = false; window.toast && toast("error", "Error de red");
        }
      });
    }
  })();
  </script>
</form>
