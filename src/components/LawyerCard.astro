---
interface Props {
  name: string;
  position: string;
  photo?: string;
  specialty?: string;
  bio?: string;
  phone?: string;
  email?: string;
  /** Compatibilidad con frontmatter, ignorados en esta versión. */
  photoZoom?: number;
  photoFocusY?: number;
}

const { name, position, photo, specialty, bio, phone, email } = Astro.props;
const photoSrc =
  photo && photo.trim() !== ""
    ? photo
    : `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=434c8c&color=ccbc54&size=720&font-size=0.35&bold=true`;

const phoneHref = phone ? phone.replace(/[^+\d]/g, "") : "";
---

<article
  class="lawyer-card group relative isolate w-full overflow-hidden bg-stone-dark shadow-sm transition-shadow hover:shadow-xl focus-within:shadow-xl"
  tabindex="0"
>
  {/* Foto al 100%, define la altura de la card */}
  <img
    src={photoSrc}
    alt={`Fotografía de ${name}`}
    class="block w-full h-auto"
    loading="lazy"
    decoding="async"
  />

  {/* Banda inferior siempre visible: nombre + cargo (navy, igual que antes) */}
  <div
    class="absolute inset-x-0 bottom-0 z-10 transition-opacity duration-300 group-hover:opacity-0 group-focus-within:opacity-0"
  >
    {/* Gradiente extendido para suavizar */}
    <div class="h-24 bg-gradient-to-t from-ink to-transparent"></div>
    {/* Caja sólida con el nombre */}
    <div class="bg-ink px-5 py-4 text-center">
      <h3 class="font-serif text-lg md:text-xl font-semibold text-white leading-tight">
        {name}
      </h3>
      <p class="mt-1 text-[10px] md:text-xs uppercase tracking-widest text-gold-light">
        {position}
      </p>
    </div>
  </div>

  {/* Overlay hover/focus en GRIS OSCURO con texto blanco */}
  <div
    class="absolute inset-0 z-20 flex flex-col justify-end px-5 py-6 md:px-6 md:py-7 opacity-0 translate-y-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:translate-y-0"
    style="background-color: #3a3a3a;"
  >
    <h3 class="font-serif text-xl md:text-2xl font-semibold text-white leading-tight">
      {name}
    </h3>
    <p class="mt-1 text-[10px] md:text-xs uppercase tracking-[0.18em] text-gold-light font-semibold">
      {position}
    </p>

    <div class="my-3 h-px w-10 bg-gold"></div>

    {specialty && (
      <p class="text-sm text-white/90 mb-3 font-medium">
        {specialty}
      </p>
    )}

    {(phone || email) && (
      <ul class="space-y-1.5 mb-3 text-sm">
        {phone && (
          <li class="flex items-center gap-2 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 text-gold-light">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <a href={`tel:${phoneHref}`} class="hover:text-gold-light transition-colors">
              {phone}
            </a>
          </li>
        )}
        {email && (
          <li class="flex items-center gap-2 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 text-gold-light">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <a href={`mailto:${email}`} class="hover:text-gold-light transition-colors break-all">
              {email}
            </a>
          </li>
        )}
      </ul>
    )}

    {bio && (
      <p class="text-xs md:text-sm leading-relaxed text-white/90 line-clamp-5 whitespace-pre-line">
        {bio}
      </p>
    )}
  </div>
</article>
