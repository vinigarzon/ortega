---
interface Props {
  eyebrow?: string;
  title: string;
  center?: boolean;
  light?: boolean;
  /** Si true, el título se renderiza en dorado en vez de navy. */
  gold?: boolean;
}

const { eyebrow, title, center = true, light = false, gold = false } = Astro.props;

const titleColor = gold
  ? "text-gold"
  : light
    ? "text-white"
    : "text-ink";
---

<div class={`mb-10 md:mb-14 ${center ? "text-center" : ""}`}>
  {eyebrow && (
    <p class={`text-xs font-semibold uppercase tracking-widest ${
      light ? "text-gold-light" : "text-gold"
    }`}>
      {eyebrow}
    </p>
  )}
  <h2
    class={`mt-2 font-serif text-3xl font-bold leading-tight md:text-4xl lg:text-5xl ${titleColor}`}
  >
    {title}
  </h2>
  <div class={`${center ? "mx-auto" : ""} divider`}></div>
</div>
