# Copia este archivo a `.env` y rellena los valores reales.
# En Netlify: ponlos en Site settings → Environment variables.

# ---- Resend (envío de correos transaccionales) ----
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Ortega & Ortega Abogados <ortega@gurumba.com>"
CONTACT_TO="orgabogados@hotmail.com"

# URL pública (para enlaces y logo en los emails)
SITE_URL="https://ortegaortegaabogados.com"

# ---- Turso (BD libSQL) ----
# Crea la BD en https://turso.tech → Database URL + Auth Token
TURSO_URL="libsql://NOMBRE-USUARIO.turso.io"
TURSO_AUTH_TOKEN="eyJhbGc..."

# ---- Cloudinary (gestión de imágenes) ----
# https://cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="xxxxxxxxxxxxxxxxxxxx"
# Mismo cloud_name pero PUBLIC_ para usarlo en el widget de subida en el navegador
PUBLIC_CLOUDINARY_CLOUD_NAME="tu-cloud-name"

# ---- Auth (JWT) ----
# Cadena aleatoria larga. Genera una con: openssl rand -base64 48
JWT_SECRET="cadena-aleatoria-de-al-menos-32-caracteres"

# ---- Bootstrap de usuarios admin ----
# Solo se usa al ejecutar `npm run db:init`. Lista usuario:password separados por coma.
# Cambia las contraseñas tras el primer login.
ADMIN_BOOTSTRAP_USERS="admin@ejemplo.com:CambiaMe123"

# ---- Cloudflare Turnstile (anti-spam, opcional) ----
# Crear sitio en https://dash.cloudflare.com/?to=/:account/turnstile
# Deja vacíos para desactivar Turnstile (queda solo honeypot + timestamp).
PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
